#!/usr/bin/env sh
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

if [ -x "$SCRIPT_DIR/.venv/Scripts/python.exe" ]; then
  exec "$SCRIPT_DIR/.venv/Scripts/python.exe" -m protocol.node "$@"
elif [ -x "$SCRIPT_DIR/.venv/bin/python" ]; then
  exec "$SCRIPT_DIR/.venv/bin/python" -m protocol.node "$@"
elif command -v python3 >/dev/null 2>&1; then
  exec python3 -m protocol.node "$@"
else
  exec python -m protocol.node "$@"
fi
